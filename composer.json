{
    "name": "afernandes/yii2-passkey",
    "description": "Yii2 extension providing Passkey (WebAuthn) authentication with support for Face ID, Touch ID, Windows Hello and Android Biometrics.",
    "type": "yii2-extension",
    "keywords": [
        "yii2",
        "webauthn",
        "passkey",
        "faceid",
        "touchid",
        "windows-hello",
        "authentication"
    ],
    "license": "MIT",
    "homepage": "https://github.com/afernandes465/yii2-passkey",
    "support": {
        "issues": "https://github.com/afernandes465/yii2-passkey/issues",
        "source": "https://github.com/afernandes465/yii2-passkey"
    },
    "authors": [
        {
            "name": "António Fernandes",
            "email": "afernandes465@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "bootstrap": "Afernandes\\Yii2Passkey\\Bootstrap",
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "require": {
        "php": "^8.1",
        "phpdocumentor/reflection-docblock": "^5.2",
        "symfony/property-access": "^6.4",
        "symfony/property-info": "^6.4",
        "symfony/serializer": "^6.4",
        "web-auth/webauthn-lib": "^4.9",
        "yiisoft/yii2": "^2.0.55"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Afernandes\\Yii2Passkey\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Afernandes\\Yii2Passkey\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
